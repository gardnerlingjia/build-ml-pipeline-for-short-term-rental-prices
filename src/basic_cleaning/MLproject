name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_name:
        description: input_name
        type: str

      output_name:
        description: output_name
        type: str

      output_type:
        description: output_type
        type: str

      output_description:
        description: output_description
        type: str

      min_price:
        description: min_price
        type: float

      max_price:
        description: max_price
        type: float

    command: >-
      python run.py
      --input_name {input_name}
      --output_name {output_name}
      --output_type {output_type}
      --output_description {output_description}
      --min_price {min_price}
      --max_price {max_price}
